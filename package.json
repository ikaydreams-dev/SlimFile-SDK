{
  "name": "@slimfile/sdk",
  "version": "1.0.1",
  "description": "Official JavaScript/TypeScript SDK for the SlimFile API — compress images, PDFs, and Office documents programmatically with up to 95% file size reduction.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src examples",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "slimfile",
    "compress",
    "image",
    "pdf",
    "office",
    "compression",
    "sdk",
    "api",
    "jpeg",
    "png",
    "webp",
    "docx",
    "xlsx",
    "pptx"
  ],
  "author": "SlimFile <support@slim-file.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikaydreams-dev/slimfile-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/ikaydreams-dev/slimfile-sdk/issues"
  },
  "homepage": "https://api.slim-file.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
